<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <!-- AI 助理平台 v28.6.19.18.228：避免 IIS / 瀏覽器持續使用舊版前端靜態檔。 -->
    <staticContent>
      <clientCache cacheControlMode="DisableCache" />
    </staticContent>
    <httpProtocol>
      <customHeaders>
        <remove name="Cache-Control" />
        <remove name="Pragma" />
        <remove name="Expires" />
        <add name="Cache-Control" value="no-cache, no-store, must-revalidate" />
        <add name="Pragma" value="no-cache" />
        <add name="Expires" value="0" />
      </customHeaders>
    </httpProtocol>
  </system.webServer>
</configuration>
